{%- assign mainMenu = linklists[section.settings.menu].links -%}
{%- assign jsLogo = settings.logo -%}

<!-- CSS link -->
{{ 'js-header.css' | asset_url | stylesheet_tag }}

<header id="js-header">
  <div class="js-header-container">
    <div class="header-empty"></div>
    <div class="header-upper-nav">
      <svg class="upper-nav-field search-icon">
        <i class="fa-brands fa-sistrix"></i>
      </svg>
      <svg class="upper-nav-field cart-icon">
        <i class="fa-solid fa-shirt"></i>
      </svg>
      <svg class="upper-nav-field account-icon">
        <i class="fa-solid fa-cart-shopping"></i>
      </svg>
    </div>
  </div>
  <a href="{{ routes.root.url }}">
    {% if jsLogo != blank %}
      {{ jsLogo | image_url: width: 400 | image_tag: class: 'js-header-logo' }}
    {% else %}
      {% comment %} NAO ESQUECA DE SUBSTITUIR O TITULO <h1>{{ shop.name }}</h1> {% endcomment %}
      <h1>{{ shop.name }}</h1>
    {% endif %}
  </a>
</header>

{% schema %}
{
  "name": "JS Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Jersey Soul Header"
    },
    {
      "type": "image_picker",
      "id": "jsLogo",
      "label": "Jersey Soul Logo"
    }
  ],
  "presets": [
    {
      "name": "Jersey Soul Header",
      "category": "Header",
      "blocks": [
        {
          "type": "_header-logo"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "_header-logo"
    }
  ]
}
{% endschema %}
