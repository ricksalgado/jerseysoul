{%- assign mainMenu = linklists[section.settings.menu].links -%}

<!-- CSS link -->
{{ 'js-header.css' | asset_url | stylesheet_tag }}


<header id="js-header">
    <a href="{{ routes.root.url }}">
        {% if section.settings.logo != blank %}
            {{ section.settings.logo | image_url: width: 250 | image_tag: loading: 'eager' }}
        {% else %}
            <h1>{{ shop.name }}</h1>
        {% endif %}

    </a>
    <div>

    </div>

</header>

{% schema %}
{

    "name": "JS Header",
    "settings": [
        {
            "type": "link_list",
            "id": "menu",
            "label": "Jersey Soul Header"
        }
    ],
    "presets": [
        {
            "name": "Jersey Soul Header",
            "category": "Header",
            "blocks": [
                {
                    "type": "_header-logo"
                }
            ]
        }
    ],
    "blocks": [
        {
            "type": "_header-logo"
        }
        
    ]

}
{% endschema %}
